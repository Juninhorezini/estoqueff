{
  "name": "estoqueff",
  "version": "2.0.0",
  "private": true,
  "dependencies": {
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.6.0",
    "jsqr": "^1.4.0",
    "lucide-react": "^0.263.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "xlsx": "^0.18.5"
  },
  "scripts": {
    "sync-src": "node -e \"const fs=require('fs'); const path=require('path'); fs.mkdirSync('src',{recursive:true}); ['index.js','index.css','App.js','App.css','App.test.js'].forEach((f)=>{ if(fs.existsSync(f)) fs.copyFileSync(f, path.join('src', f)); });\"",
    "prestart": "npm run sync-src",
    "start": "react-scripts start",
    "prebuild": "npm run sync-src",
    "build": "react-scripts build",
    "pretest": "npm run sync-src",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1"
  }
}
